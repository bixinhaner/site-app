# Web Admin 环境配置示例文件
# 复制此文件为 .env.local 或 .env.production 并修改对应的值

# ================================
# API 服务器配置
# ================================
# 开发环境 - 本地开发时使用
# VITE_API_BASE_URL=http://localhost:8000

# 生产环境 - 服务器部署时修改为实际IP地址
# VITE_API_BASE_URL=http://192.168.1.100:8000

# 如果前后端部署在同一台服务器，可以使用相对路径
# 这样客户端会自动使用当前域名访问API
# VITE_API_BASE_URL=

# ================================
# 其他配置项
# ================================
# 应用名称
VITE_APP_NAME=站点信息管理系统

# 应用版本
VITE_APP_VERSION=1.0.0

# 是否启用开发模式日志
VITE_ENABLE_DEBUG=false