# 应用配置
APP_NAME=站点信息管理系统
API_V1_STR=/api/v1
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=true

# 启动自检：默认管理员（仅首次创建；已存在不会重置密码）
AUTO_CREATE_ADMIN=true
DEFAULT_ADMIN_USERNAME=admin
# 生产环境务必修改默认密码
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_FULL_NAME=系统管理员

# 数据库配置（开发环境使用SQLite）
DATABASE_URL=sqlite:///./site_manager.db

# 生产环境可使用MySQL
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/site_manager

# JWT配置
# 短期 Access Token 过期时间（分钟）
# 默认设置为 4320 分钟（3 天），便于在 Web 管理端获得较好的登录体验。
ACCESS_TOKEN_EXPIRE_MINUTES=4320
# 长期 Refresh Token 过期时间（天）
# 表示无操作超过 3 天需要重新登录。
REFRESH_TOKEN_EXPIRE_DAYS=3
ALGORITHM=HS256

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES_STR=jpg,jpeg,png,pdf

# CORS配置
ALLOWED_HOSTS_STR=*

# Redis配置（可选）
# REDIS_URL=redis://localhost:6379/0

# 邮件配置（可选）
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-email-password

# 逆地理（国内）：百度 Web 服务 AK（用于 /api/geo/baidu-reverse 的国内坐标）
# BAIDU_MAP_AK=

# 逆地理（海外）：Google Maps Platform Key（Geocoding API，用于海外坐标）
# GOOGLE_MAPS_API_KEY=

# Google 逆地理 Relay（可选：用于部署在中国境内的后端无法直连 Google 的场景）
# - 在中国境内后端：配置下面两项后，将优先通过 Relay 转发请求（可不配置 GOOGLE_MAPS_API_KEY）
# - 在境外 Relay 服务器：需要配置 GOOGLE_MAPS_API_KEY，并部署一个简单的 Relay 服务
# GOOGLE_GEOCODE_RELAY_URL=http://<overseas-ip>:19080/api/geo/google-reverse
# GOOGLE_GEOCODE_RELAY_TOKEN=change-me

# AI（OpenAI 兼容：Deepseek 等）
# 例：Deepseek（OpenAI-compat）
# AI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat
# AI_API_KEY=sk-xxxxxxxx
# 可选项：若你的 base_url 已包含 /v1，可保持默认；否则保持默认即可
# AI_CHAT_COMPLETIONS_PATH=/v1/chat/completions
# AI_TIMEOUT_SECONDS=60
# AI_TEMPERATURE=0.2
# AI_MAX_TOKENS=1024
# AI_BATCH_CHUNK_SIZE=20
# AI_DOMAIN_HINT=无线通信行业（站点巡检/工单系统）

# AI Vision（OpenAI 兼容：支持 image_url 多模态）
# - 若不配置该段，则检查项 AI 的 mode=auto 在有图片时会自动降级为 text 模式（只分析字段/元数据）
# - Azure OpenAI 示例（注意：model 通常填“部署名”，并需要 api-version）
# AI_VISION_BASE_URL=https://<resource>.openai.azure.com
# AI_VISION_MODEL=<your-azure-deployment-name>
# AI_VISION_API_KEY=xxxxxxxx
# AI_VISION_CHAT_COMPLETIONS_PATH=/openai/deployments/<your-azure-deployment-name>/chat/completions?api-version=2024-02-15-preview
# AI_VISION_TIMEOUT_SECONDS=60
# AI_VISION_TEMPERATURE=0.2
# AI_VISION_MAX_TOKENS=1024
