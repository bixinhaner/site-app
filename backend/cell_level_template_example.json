{
  "template_name": "5G基站小区级检查模板",
  "template_data": {
    "check_categories": [
      {
        "category_id": "site_basic",
        "category_name": "站点基础检查",
        "sector_specific": false,
        "cell_specific": false,
        "items": [
          {
            "item_id": "site_power",
            "item_name": "电源检查",
            "required_type": "both",
            "data_fields": [
              {
                "field_id": "power_voltage",
                "field_name": "电源电压",
                "field_type": "number",
                "unit": "V",
                "validation": {
                  "min": 220,
                  "max": 240
                }
              }
            ]
          },
          {
            "item_id": "site_environment",
            "item_name": "环境检查",
            "required_type": "photo"
          }
        ]
      },
      {
        "category_id": "sector_physical", 
        "category_name": "扇区物理检查",
        "sector_specific": true,
        "cell_specific": false,
        "items": [
          {
            "item_id": "antenna_installation",
            "item_name": "天线安装检查",
            "required_type": "both",
            "data_fields": [
              {
                "field_id": "antenna_azimuth",
                "field_name": "天线方位角",
                "field_type": "number",
                "unit": "度",
                "validation": {
                  "min": 0,
                  "max": 360
                }
              },
              {
                "field_id": "antenna_downtilt",
                "field_name": "天线下倾角",
                "field_type": "number",
                "unit": "度",
                "validation": {
                  "min": 0,
                  "max": 20
                }
              }
            ]
          }
        ]
      },
      {
        "category_id": "cell_rf",
        "category_name": "小区射频检查",
        "sector_specific": false,
        "cell_specific": true,
        "items": [
          {
            "item_id": "cell_power",
            "item_name": "小区功率测量",
            "required_type": "both",
            "data_fields": [
              {
                "field_id": "tx_power",
                "field_name": "发射功率",
                "field_type": "number",
                "unit": "dBm",
                "validation": {
                  "min": 30,
                  "max": 46
                }
              },
              {
                "field_id": "vswr",
                "field_name": "驻波比",
                "field_type": "number",
                "validation": {
                  "min": 1.0,
                  "max": 2.0
                }
              }
            ]
          },
          {
            "item_id": "cell_coverage",
            "item_name": "小区覆盖测试",
            "required_type": "both",
            "data_fields": [
              {
                "field_id": "rsrp",
                "field_name": "RSRP",
                "field_type": "number",
                "unit": "dBm",
                "validation": {
                  "min": -120,
                  "max": -70
                }
              },
              {
                "field_id": "sinr",
                "field_name": "SINR",
                "field_type": "number", 
                "unit": "dB",
                "validation": {
                  "min": 0,
                  "max": 30
                }
              }
            ]
          }
        ]
      },
      {
        "category_id": "cell_config",
        "category_name": "小区配置检查",
        "sector_specific": false,
        "cell_specific": true,
        "items": [
          {
            "item_id": "cell_params",
            "item_name": "小区参数配置",
            "required_type": "data",
            "data_fields": [
              {
                "field_id": "pci",
                "field_name": "PCI",
                "field_type": "number",
                "validation": {
                  "min": 0,
                  "max": 1007
                }
              },
              {
                "field_id": "earfcn",
                "field_name": "频点",
                "field_type": "number"
              },
              {
                "field_id": "bandwidth",
                "field_name": "带宽",
                "field_type": "select",
                "options": ["5MHz", "10MHz", "15MHz", "20MHz", "100MHz"]
              }
            ]
          }
        ]
      }
    ]
  },
  "description": "支持小区级检查的5G基站检查模板，可根据站点规划数据自动生成对应数量的小区检查项"
}